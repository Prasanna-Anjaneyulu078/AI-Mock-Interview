# ── Required ──
# JWT signing secret. MUST be a Base64-encoded string that decodes to >= 32 bytes
# (256 bits) for HS256. Generate one with:  openssl rand -base64 32
# If unset, the backend FAILS TO START (enforced by SecurityConfigValidator).
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── AI Providers (all optional — each disables gracefully when blank) ──
# OpenRouter (Primary AI Provider)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Groq (Secondary AI Provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (Local AI Provider)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AssemblyAI: speech-to-text for voice answers.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_TIMEOUT_MS=30000
ASSEMBLYAI_POLL_TIMEOUT_MS=60000
ASSEMBLYAI_MAX_POLLS=20

# Murf: text-to-speech for the interviewer voice.
MURF_API_KEY=
MURF_DEFAULT_VOICE=en-US-natalie
MURF_DEFAULT_STYLE=Conversational
MURF_TIMEOUT_MS=10000
MURF_MAX_RETRIES=3

# Judge0: real code-execution grading (optional; falls back to AI scoring if blank).
JUDGE0_URL=
JUDGE0_API_KEY=
JUDGE0_TIMEOUT_MS=30000

# ── Database (used by docker-compose and the backend) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mockinterview
DB_USER=postgres
DB_PASSWORD=password123

# ── CORS (comma-separated allowed origins) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
